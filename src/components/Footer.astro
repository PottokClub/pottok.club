---
const navLinks = [
  { label: 'Nos avantages', href: '/#avantages' },
  { label: 'Comment ça marche', href: '/#ccm' },
  { label: 'Témoignages', href: '/#temoignages' },
  { label: 'FAQ', href: '/#faq' },
  { label: 'Blog', href: '/blog' },
];

const socialLinks = [
  {
    label: 'Facebook',
    href: 'https://www.facebook.com/profile.php?id=100089255415091&locale=fr_FR',
    icon: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z',
  },
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/pottok.club/',
    icon: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z',
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/company/pottok-club/',
    icon: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  },
];

const appStoreUrl = 'https://apps.apple.com/fr/app/pottok-chevaux-en-demi-pension/id6458321351';
const playStoreUrl = 'https://play.google.com/store/apps/details?id=com.mycompany.pottokapp&hl=fr';
---

<footer class="bg-footer-bg text-white/80">
  <div class="mx-auto max-w-7xl px-5 py-16">
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand & Newsletter -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="mb-4 flex items-center gap-2">
          <img src="/favicon.png" alt="Pottok" width="32" height="32" class="rounded-lg" />
          <span class="font-heading text-xl font-800 text-white">Pottok</span>
        </a>
        <p class="mb-6 text-sm leading-relaxed text-white/60">
          Inscrivez-vous à notre lettre d'information pour être tenu au courant des nouveautés.
        </p>
        <form class="flex gap-2" onsubmit="return false;">
          <input
            type="email"
            placeholder="Votre email"
            class="flex-1 rounded-[var(--radius-pill)] border border-white/20 bg-white/10 px-4 py-2.5 text-sm text-white placeholder-white/40 outline-none focus:border-primary"
          />
          <button
            type="submit"
            class="rounded-[var(--radius-pill)] bg-primary px-5 py-2.5 text-sm font-600 text-white transition-colors hover:bg-primary-hover"
          >
            OK
          </button>
        </form>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="mb-5 font-heading text-sm font-700 uppercase tracking-wider text-white">
          Explore Pottok
        </h4>
        <nav class="flex flex-col gap-3">
          {navLinks.map((link) => (
            <a href={link.href} class="text-sm text-white/60 transition-colors hover:text-white">
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Download App -->
      <div>
        <h4 class="mb-5 font-heading text-sm font-700 uppercase tracking-wider text-white">
          Télécharger l'app
        </h4>
        <div class="flex flex-col gap-3">
          <a
            href={appStoreUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 rounded-[var(--radius-badge)] border border-white/20 bg-white/5 px-4 py-2.5 transition-colors hover:bg-white/10"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="24" viewBox="0 0 384 512" fill="currentColor" class="text-white">
              <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/>
            </svg>
            <div class="flex flex-col">
              <span class="text-[10px] leading-none text-white/50">Télécharger sur</span>
              <span class="text-sm font-600 text-white">App Store</span>
            </div>
          </a>
          <a
            href={playStoreUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 rounded-[var(--radius-badge)] border border-white/20 bg-white/5 px-4 py-2.5 transition-colors hover:bg-white/10"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="22" viewBox="0 0 512 512" fill="currentColor" class="text-white">
              <path d="M325.3 234.3L104.6 13l280.8 161.2-60.1 60.1zM47 0C34 6.8 25.3 19.2 25.3 35.3v441.3c0 16.1 8.7 28.5 21.7 35.3l256.6-256L47 0zm425.2 225.6l-58.9-34.1-65.7 64.5 65.7 64.5 60.1-34.1c18-14.3 18-46.5-1.2-60.8zM104.6 499l280.8-161.2-60.1-60.1L104.6 499z"/>
            </svg>
            <div class="flex flex-col">
              <span class="text-[10px] leading-none text-white/50">Disponible sur</span>
              <span class="text-sm font-600 text-white">Google Play</span>
            </div>
          </a>
        </div>
      </div>

      <!-- Social -->
      <div>
        <h4 class="mb-5 font-heading text-sm font-700 uppercase tracking-wider text-white">
          Suivez-nous
        </h4>
        <div class="flex gap-3">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
              class="flex h-10 w-10 items-center justify-center rounded-full border border-white/20 text-white/60 transition-colors hover:border-primary hover:text-white"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 flex flex-col items-center gap-4 border-t border-white/10 pt-8 sm:flex-row sm:justify-between">
      <p class="text-sm text-white/40">
        &copy; 2026 Pottok - Tous droits réservés
      </p>
      <div class="flex flex-wrap gap-4 text-sm text-white/40">
        <a href="/mentions-legales" class="transition-colors hover:text-white/60">Mentions légales</a>
        <a href="/politique-de-confidentialite" class="transition-colors hover:text-white/60">Confidentialité</a>
        <a href="/cgv" class="transition-colors hover:text-white/60">CGV</a>
        <a href="javascript:void(window.axeptioSettings && window.axeptioSettings.show ? window.axeptioSettings.show() : alert('Cookies manager loading...'))" class="transition-colors hover:text-white/60">Cookies</a>
      </div>
    </div>
  </div>
</footer>
