---
// Newsletter form component
---

<div class="newsletter-container">
  <form id="newsletter-form" class="flex gap-2">
    <input
      type="email"
      id="newsletter-email"
      name="email"
      placeholder="Votre email"
      required
      class="flex-1 rounded-[var(--radius-pill)] border border-white/20 bg-white/10 px-4 py-2.5 text-sm text-white placeholder-white/40 outline-none focus:border-primary"
    />
    <button
      type="submit"
      id="newsletter-submit"
      class="rounded-[var(--radius-pill)] bg-primary px-5 py-2.5 text-sm font-600 text-white transition-colors hover:bg-primary-hover disabled:opacity-50 disabled:cursor-not-allowed"
    >
      OK
    </button>
  </form>
  <p id="newsletter-message" class="mt-2 text-sm text-white/60 hidden"></p>
</div>

<script>
  // Newsletter subscription handler
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;
  const submitBtn = document.getElementById('newsletter-submit') as HTMLButtonElement;
  const message = document.getElementById('newsletter-message') as HTMLParagraphElement;

  if (form && emailInput && submitBtn && message) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const email = emailInput.value.trim();
      if (!email) return;

      // Validation email simple
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email)) {
        showMessage('Adresse email invalide', 'error');
        return;
      }

      // Disable form
      submitBtn.disabled = true;
      submitBtn.textContent = '...';

      try {
        // Enregistrer dans Firestore via l'API
        const response = await fetch('https://europe-west1-pottok-7b9ef.cloudfunctions.net/subscribeNewsletter', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ email }),
        });

        if (response.ok) {
          showMessage('Merci ! Vous êtes inscrit(e) à notre newsletter 🎉', 'success');
          emailInput.value = '';
        } else {
          const data = await response.json();
          showMessage(data.message || 'Une erreur est survenue', 'error');
        }
      } catch (error) {
        console.error('Newsletter error:', error);
        showMessage('Une erreur est survenue. Réessayez plus tard.', 'error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'OK';
      }
    });
  }

  function showMessage(text: string, type: 'success' | 'error') {
    if (!message) return;
    
    message.textContent = text;
    message.className = type === 'success' 
      ? 'mt-2 text-sm text-green-400' 
      : 'mt-2 text-sm text-red-400';
    message.classList.remove('hidden');
    
    // Auto-hide after 5s
    setTimeout(() => {
      message.classList.add('hidden');
    }, 5000);
  }
</script>
