---
const annonces = [
  {
    name: 'Bella',
    level: 'Débutant',
    price: '120€/mois',
    location: 'Rue de l\'Église 69380 Lissieu',
    type: 'Demi-pension',
    frequency: '2/semaine',
    image: '/images/horse-bella.jpg',
  },
  {
    name: 'Orion',
    level: 'Confirmé',
    price: '220€/mois',
    location: '77710 Villemaréchal, France',
    type: 'Demi-pension',
    frequency: '3/semaine',
    image: '/images/horse-orion.jpg',
  },
  {
    name: 'Elfi',
    level: 'Confirmé',
    price: '120€/mois',
    location: '34000 Montpellier, France',
    type: 'Demi-pension',
    frequency: '2/semaine',
    image: '/images/horse-elfi.png',
  },
  {
    name: 'Nikita',
    level: 'Débutant',
    price: '170€/mois',
    location: '09300 Lavelanet, France',
    type: 'Demi-pension',
    frequency: '2/semaine',
    image: '/images/horse-nikita.png',
  },
];
---

<section id="annonces" class="bg-background py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-5">
    <!-- Section header -->
    <div class="mx-auto mb-14 max-w-2xl text-center">
      <h2 class="font-heading text-[clamp(1.625rem,4vw,2.5rem)] font-800 leading-tight text-foreground">
        Découvre les dernières annonces de chevaux disponibles
      </h2>
      <p class="mt-4 text-lg text-body">
        Trouve le cheval parfait près de chez toi parmi des centaines d'annonces actualisées.
      </p>
    </div>

    <!-- Cards Grid -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {annonces.map((annonce) => (
        <div class="group overflow-hidden rounded-[var(--radius-card)] border border-border bg-background shadow-sm transition-shadow hover:shadow-card">
          <!-- Horse photo -->
          <div class="aspect-[4/3] overflow-hidden bg-muted">
            <img src={annonce.image} alt={annonce.name} width="400" height="300" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
          </div>

          <!-- Content -->
          <div class="p-4">
            <div class="mb-2 flex items-center justify-between">
              <h3 class="font-heading text-lg font-700 text-foreground">{annonce.name}</h3>
              <span class={`rounded-[var(--radius-pill)] px-2.5 py-0.5 text-xs font-600 ${annonce.level === 'Débutant' ? 'bg-badge-bg text-badge-text' : 'bg-primary/10 text-primary'}`}>
                {annonce.level}
              </span>
            </div>

            <p class="text-xl font-700 text-primary">{annonce.price}</p>

            <div class="mt-3 space-y-1.5 text-sm text-muted-foreground">
              <div class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
                </svg>
                <span class="line-clamp-1">{annonce.location}</span>
              </div>
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
                  <path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/>
                </svg>
                <span>{annonce.type} - {annonce.frequency}</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-12 text-center">
      <a
        href="https://apps.apple.com/fr/app/pottok-chevaux-en-demi-pension/id6458321351"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-[var(--radius-pill)] bg-primary px-8 py-3.5 text-base font-600 text-white transition-colors hover:bg-primary-hover"
      >
        Voir toutes les annonces
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
