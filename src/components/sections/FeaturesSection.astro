---
const features = [
  {
    title: 'Enregistre tes coups de c\u0153ur',
    description: 'Garde en favori les chevaux ou cavaliers qui te correspondent et précise ta recherche selon tes besoins : disciplines, race, distance, etc.',
  },
  {
    title: 'Organise tes séances simplement',
    description: 'Planifiez facilement vos jours de monte avec le calendrier collaboratif, pour une gestion claire et partagée des entraînements.',
  },
  {
    title: 'Un contrat sans tracas',
    description: 'Obtiens un contrat de demi-pension personnalisé en quelques minutes, pour une relation en toute confiance.',
  },
  {
    title: 'Échangez en direct avec les propriétaires/cavaliers',
    description: 'Discute en temps réel avec les propriétaires ou cavaliers, pose toutes tes questions et planifie tes essais.',
  },
  {
    title: 'Sois le premier informé',
    description: 'Ne manque plus aucune opportunité ! Reçois instantanément une notification dès qu\'une demi-pension correspondant à tes critères est disponible près de chez toi.',
  },
];

const featureIcons = [
  // Heart / Favorites
  'M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z',
  // Calendar
  'M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z',
  // FileText / Contract
  'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8',
  // MessageCircle
  'M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z',
  // Bell / Alerts
  'M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9 M13.73 21a2 2 0 0 1-3.46 0',
];

const featureImages = [
  '/images/feature-recherche.png',
  '/images/feature-recherche.png',
  '/images/feature-contrat.png',
  '/images/feature-messagerie.png',
  '/images/feature-alertes.png',
];
---

<section id="avantages" class="bg-background py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-5">
    <!-- Section header -->
    <div class="mx-auto mb-16 max-w-2xl text-center md:mb-20">
      <h2 class="font-heading text-[clamp(1.625rem,4vw,2.5rem)] font-800 leading-tight text-foreground">
        Ce qui rend Pottok parfait pour ta demi-pension
      </h2>
    </div>

    <!-- Features -->
    <div class="space-y-16 md:space-y-24">
      {features.map((feature, index) => (
        <div class={`flex flex-col items-center gap-10 md:gap-16 ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
          <!-- Phone mockup -->
          <div class="w-full md:w-1/2">
            <div class="mx-auto max-w-[280px] overflow-hidden rounded-[2rem] bg-muted shadow-card">
              <img src={featureImages[index]} alt={feature.title} width="280" height="497" class="w-full h-auto" loading="lazy" />
            </div>
          </div>

          <!-- Text content -->
          <div class="w-full md:w-1/2">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-badge-bg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                <path d={featureIcons[index]} />
              </svg>
            </div>
            <h3 class="font-heading text-[clamp(1.375rem,3vw,1.75rem)] font-700 leading-snug text-foreground">
              {feature.title}
            </h3>
            <p class="mt-4 text-lg leading-relaxed text-body">
              {feature.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
