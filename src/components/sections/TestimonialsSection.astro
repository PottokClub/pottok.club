---
const testimonials = [
  {
    name: 'Léa',
    role: 'Cavalière',
    text: "Grâce à Pottok, j'ai trouvé le cheval parfait en demi-pension près de chez moi en à peine quelques jours. L'application est super facile à utiliser et m'a vraiment simplifié la vie. Merci Pottok !",
    image: '/images/avatar-lea.png',
  },
  {
    name: 'Jean',
    role: 'Propriétaire',
    text: "Pottok m'a vraiment simplifié la vie pour trouver des cavalières sérieuses. En quelques clics, mon cheval a trouvé la cavalière idéale, et j'ai pu gérer toutes les demandes directement depuis l'app. Je recommande à 100% !",
    image: '/images/avatar-jean.png',
  },
];
---

<section id="temoignages" class="bg-background py-20 md:py-28">
  <div class="mx-auto max-w-5xl px-5">
    <!-- Section header -->
    <div class="mx-auto mb-14 max-w-2xl text-center">
      <h2 class="font-heading text-[clamp(1.625rem,4vw,2.5rem)] font-800 leading-tight text-foreground">
        Ils partagent leur expérience avec Pottok
      </h2>
    </div>

    <!-- Testimonial cards -->
    <div class="grid gap-8 md:grid-cols-2">
      {testimonials.map((testimonial) => (
        <div class="rounded-[var(--radius-card)] border border-border bg-background p-8 shadow-card">
          <!-- Stars -->
          <div class="mb-5 flex gap-1">
            {[1, 2, 3, 4, 5].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-amber-400">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="mb-6 text-base leading-relaxed text-body">
            "{testimonial.text}"
          </blockquote>

          <!-- Author -->
          <div class="flex items-center gap-3">
            <img src={testimonial.image} alt={testimonial.name} width="44" height="44" class="h-11 w-11 rounded-full object-cover" loading="lazy" />
            <div>
              <p class="font-600 text-foreground">{testimonial.name}</p>
              <p class="text-sm text-muted-foreground">{testimonial.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
