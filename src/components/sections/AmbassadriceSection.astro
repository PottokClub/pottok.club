---
---

<section class="bg-muted py-20 md:py-28">
  <div class="mx-auto max-w-4xl px-5">
    <!-- Section header -->
    <div class="mx-auto mb-10 max-w-2xl text-center">
      <h2 class="font-heading text-[clamp(1.625rem,4vw,2.5rem)] font-800 leading-tight text-foreground">
        L'avis de notre ambassadrice Pottok
      </h2>
      <p class="mt-4 text-lg text-body">
        Pourquoi Pottok est la solution idéale pour la demi-pension, par Carnet de Légende, notre ambassadrice.
      </p>
    </div>

    <!-- Video (portrait 9:16) -->
    <div class="mx-auto max-w-sm overflow-hidden rounded-[var(--radius-card)] border border-border shadow-card">
      <video
        controls
        preload="metadata"
        class="aspect-[9/16] w-full bg-black object-cover"
      >
        <source src="/videos/ambassadrice.mp4" type="video/mp4" />
        Votre navigateur ne supporte pas la lecture vidéo.
      </video>
    </div>
  </div>
</section>
