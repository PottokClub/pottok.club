---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page introuvable | Pottok" description="La page que vous recherchez n'existe pas.">
  <Header />

  <main class="flex min-h-[60vh] items-center justify-center pt-20 pb-20">
    <div class="mx-auto max-w-lg px-5 text-center">
      <p class="font-heading text-[6rem] font-800 leading-none text-primary/20">404</p>
      <h1 class="mt-4 font-heading text-2xl font-800 text-foreground">
        Page introuvable
      </h1>
      <p class="mt-3 text-lg text-body">
        La page que tu recherches n'existe pas ou a été déplacée.
      </p>
      <a
        href="/"
        class="mt-8 inline-flex items-center gap-2 rounded-[var(--radius-pill)] bg-primary px-8 py-3 text-base font-600 text-white transition-colors hover:bg-primary-hover"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Retour à l'accueil
      </a>
    </div>
  </main>

  <Footer />
</Layout>
