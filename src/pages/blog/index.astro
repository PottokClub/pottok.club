---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout
  title="Blog Pottok : Conseils et guides demi-pension cheval"
  description="Retrouve tous nos articles, conseils et guides sur la demi-pension cheval. Contrats, astuces, témoignages et bien plus."
>
  <Header />

  <main class="pt-28 pb-20 md:pt-36 md:pb-28">
    <div class="mx-auto max-w-7xl px-5">
      <!-- Header -->
      <div class="mx-auto mb-14 max-w-2xl text-center">
        <h1 class="font-heading text-[clamp(2rem,5vw,3rem)] font-800 leading-tight text-foreground">
          Blog Pottok
        </h1>
        <p class="mt-4 text-lg text-body">
          Conseils, guides et astuces pour réussir ta demi-pension cheval.
        </p>
      </div>

      <!-- Articles grid -->
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a
            href={`/blog/${post.data.slug}/`}
            class="group overflow-hidden rounded-[var(--radius-card)] border border-border bg-background shadow-sm transition-shadow hover:shadow-card"
          >
            <!-- Blog thumbnail -->
            <div class="aspect-[16/10] overflow-hidden bg-muted">
              {post.data.image ? (
                <img src={post.data.image} alt={post.data.title} width="400" height="250" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
              ) : (
                <div class="flex h-full items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary/20">
                    <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/>
                    <path d="M18 14h-8"/>
                    <path d="M15 18h-5"/>
                    <path d="M10 6h8v4h-8V6Z"/>
                  </svg>
                </div>
              )}
            </div>

            <!-- Content -->
            <div class="p-5">
              <div class="mb-2 flex flex-wrap gap-2">
                {post.data.tags.map((tag: string) => (
                  <span class="rounded-[var(--radius-pill)] bg-badge-bg px-2.5 py-0.5 text-xs font-500 text-badge-text">
                    {tag}
                  </span>
                ))}
              </div>
              <time class="text-sm text-muted-foreground" datetime={post.data.date}>
                {new Date(post.data.date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h2 class="mt-2 font-heading text-lg font-700 leading-snug text-foreground group-hover:text-primary transition-colors">
                {post.data.title}
              </h2>
              <p class="mt-2 line-clamp-2 text-sm text-body">
                {post.data.description}
              </p>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-600 text-primary">
                Lire l'article
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
