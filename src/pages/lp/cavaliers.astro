---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const appStoreUrl = 'https://apps.apple.com/fr/app/pottok-chevaux-en-demi-pension/id6458321351';
const playStoreUrl = 'https://play.google.com/store/apps/details?id=com.mycompany.pottokapp&hl=fr';
---

<Layout
  title="Cavaliers : trouve ta demi-pension cheval idéale | Pottok"
  description="Trouve ta demi-pension équestre en quelques minutes ! Explore les chevaux près de chez toi et contacte les propriétaires avec Pottok."
  noindex={true}
>
  <Header />

  <main class="pt-32 pb-20 md:pt-40 md:pb-28">
    <div class="mx-auto max-w-3xl px-5 text-center">
      <div class="mb-6 inline-flex items-center gap-2 rounded-[var(--radius-pill)] bg-badge-bg px-5 py-2">
        <span class="text-sm font-600 text-badge-text">Pour les cavalières</span>
      </div>

      <h1 class="font-heading text-[clamp(2rem,5vw,3.25rem)] font-800 leading-tight text-foreground">
        Trouve ta demi-pension équestre en quelques minutes&nbsp;!
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-body">
        Explore les chevaux près de chez toi, contacte les propriétaires et organise une rencontre en 2 min, peu importe ton niveau. Que tu sois débutante ou confirmée, trouve le cheval qui te correspond sans prise de tête et commence à monter rapidement&nbsp;!
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={appStoreUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 rounded-[var(--radius-badge)] bg-dark px-6 py-3.5 text-white transition-opacity hover:opacity-90">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="26" viewBox="0 0 384 512" fill="currentColor"><path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/></svg>
          <div class="flex flex-col text-left">
            <span class="text-[10px] leading-none text-white/60">Télécharger sur</span>
            <span class="text-base font-600">App Store</span>
          </div>
        </a>
        <a href={playStoreUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 rounded-[var(--radius-badge)] bg-dark px-6 py-3.5 text-white transition-opacity hover:opacity-90">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="22" viewBox="0 0 512 512" fill="currentColor"><path d="M325.3 234.3L104.6 13l280.8 161.2-60.1 60.1zM47 0C34 6.8 25.3 19.2 25.3 35.3v441.3c0 16.1 8.7 28.5 21.7 35.3l256.6-256L47 0zm425.2 225.6l-58.9-34.1-65.7 64.5 65.7 64.5 60.1-34.1c18-14.3 18-46.5-1.2-60.8zM104.6 499l280.8-161.2-60.1-60.1L104.6 499z"/></svg>
          <div class="flex flex-col text-left">
            <span class="text-[10px] leading-none text-white/60">Disponible sur</span>
            <span class="text-base font-600">Google Play</span>
          </div>
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
